---
import Page from '../../../layouts/Page.astro';
import { t } from '../../../i18n/utils';
import { getTalksByLocale, stripLocalePrefix } from '../../../lib/talks';

const lang = 'ja';
const talks = await getTalksByLocale(lang);
---

<Page title={t(lang, 'talks.title')} lang={lang} path="/talks/">
  <div class="pt-24 pb-16 max-w-4xl mx-auto px-4">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-8">{t(lang, 'talks.title')}</h1>
    <div class="space-y-4">
      {talks.map((talk) => (
        <a href={`/ja/talks/${stripLocalePrefix(talk.slug)}/`} class="block p-6 rounded-lg bg-gray-100 dark:bg-gray-900 hover:bg-gray-200 dark:hover:bg-gray-800 transition-colors">
          <h2 class="text-xl font-semibold text-gray-900 dark:text-white">{talk.data.title}</h2>
          <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">{talk.data.description}</p>
          {talk.data.venue && <p class="text-gray-400 dark:text-gray-500 text-xs mt-2">{talk.data.venue}</p>}
        </a>
      ))}
    </div>
  </div>
</Page>
