---
// Language detection redirect — serves only at /
// Browser language determines en/ or ja/, with en/ as fallback.
---

<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content="0;url=/en/" />
    <script is:inline>
      var lang = (navigator.language || '').startsWith('ja') ? 'ja' : 'en';
      window.location.replace('/' + lang + '/');
    </script>
  </head>
  <body></body>
</html>
