---
import Math from '../ui/Math.astro';
---

<div class="vs">
  <svg viewBox="0 0 680 340" preserveAspectRatio="xMidYMid meet" aria-label="Valley-shape plot: acceleration versus institutional response over time">
    <g class="axes">
      <line x1="70" y1="30" x2="70" y2="280" />
      <line x1="70" y1="280" x2="650" y2="280" />
    </g>

    <text x="28" y="155" text-anchor="middle" class="axlabel" transform="rotate(-90 28 155)">growth rate (%/yr)</text>
    <text x="360" y="318" text-anchor="middle" class="axlabel">years</text>

    <g id="vs-xticks"></g>
    <g id="vs-yticks"></g>

    <path id="vs-valley" class="valley-area" d="" />
    <path id="vs-a" class="curve curve-a" d="" />
    <path id="vs-iota" class="curve curve-iota" d="" />

    <g class="legend" transform="translate(470, 40)">
      <line x1="0" y1="4" x2="24" y2="4" class="curve-a" />
      <text x="30" y="8" class="legend-text">acceleration a(t)</text>
      <line x1="0" y1="24" x2="24" y2="24" class="curve-iota" />
      <text x="30" y="28" class="legend-text">institutional ι(t)</text>
      <rect x="0" y="38" width="24" height="12" class="valley-legend" />
      <text x="30" y="48" class="legend-text">valley (a − ι)₊</text>
    </g>

    <text id="vs-title" x="360" y="22" text-anchor="middle" class="title"></text>
  </svg>

  <div class="controls">
    <label class="preset">
      <span>scenario</span>
      <select id="vs-preset">
        <option value="engels">Engels' pause — Britain 1780-1840</option>
        <option value="deindust">US deindustrialisation 1980-</option>
        <option value="soviet">Post-Soviet transition 1991-2000</option>
        <option value="aghion" selected>Aghion-Bunel modest AI scenario</option>
        <option value="davidson">Davidson radical AI scenario</option>
        <option value="custom">Custom</option>
      </select>
    </label>
    <label>
      <span>peak acceleration <Math tex={String.raw`a_{\text{peak}}`} /> (%/yr) = <output id="vs-apeak-out"></output></span>
      <input type="range" id="vs-apeak" min="0.1" max="80" step="0.1" value="0.7" />
    </label>
    <label>
      <span>time scale <Math tex={String.raw`\sigma`} /> (yr) = <output id="vs-sigma-out"></output></span>
      <input type="range" id="vs-sigma" min="1" max="40" step="0.5" value="8" />
    </label>
    <label>
      <span>institutional catch-up <Math tex={String.raw`k`} /> (%/yr²) = <output id="vs-k-out"></output></span>
      <input type="range" id="vs-k" min="0.001" max="5" step="0.001" value="0.04" />
    </label>
  </div>

  <div class="readout">
    <span>valley length <strong id="vs-L"></strong></span>
    <span>peak depth <strong id="vs-depth"></strong></span>
    <span>integrated gap <strong id="vs-area"></strong></span>
  </div>
</div>

<style>
  .vs {
    width: 100%;
    max-width: 760px;
    margin: 0 auto;
    color: var(--post-text, #353535);
    font-family: ui-sans-serif, system-ui, sans-serif;
  }
  .vs svg { width: 100%; height: auto; display: block; }
  .vs .axes line { stroke: var(--post-separator, #bbb); stroke-width: 1; }
  .vs g#vs-xticks line,
  .vs g#vs-yticks line { stroke: var(--post-separator, #bbb); }
  .vs g#vs-xticks text,
  .vs g#vs-yticks text,
  .vs .axlabel,
  .vs .legend-text {
    fill: var(--post-caption, #737373);
    font-size: 11px;
  }
  .vs .axlabel { font-size: 12px; }
  .vs .title {
    fill: var(--post-heading, #1a1a1a);
    font-size: 13px;
    font-weight: 600;
  }
  .vs .curve { fill: none; stroke-width: 2; }
  .vs .curve-a { stroke: #1a1a1a; }
  .vs .curve-iota { stroke: #2563eb; stroke-dasharray: 5 3; }
  .vs line.curve-a { stroke-width: 2; }
  .vs line.curve-iota { stroke-width: 2; }
  .vs .valley-area { fill: #dc2626; fill-opacity: 0.22; stroke: none; }
  .vs .valley-legend { fill: #dc2626; fill-opacity: 0.22; stroke: none; }

  .vs .controls {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.9rem 1.4rem;
    margin-top: 0.9rem;
    font-size: 0.88rem;
  }
  @media (max-width: 560px) {
    .vs .controls { grid-template-columns: 1fr; }
  }
  .vs .controls label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    color: var(--post-caption, #737373);
  }
  .vs .controls input[type="range"] { accent-color: #dc2626; width: 100%; }
  .vs .controls select {
    padding: 0.3rem 0.4rem;
    font-size: 0.88rem;
    color: var(--post-heading, #1a1a1a);
    background: transparent;
    border: 1px solid var(--post-separator, #bbb);
    border-radius: 3px;
  }
  .vs .controls output { color: var(--post-heading, #1a1a1a); font-weight: 600; }
  .vs .readout {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
    margin-top: 0.7rem;
    font-size: 0.82rem;
    color: var(--post-caption, #737373);
    justify-content: center;
  }
  .vs .readout strong { color: var(--post-heading, #1a1a1a); font-weight: 600; margin-left: 0.25rem; }
</style>

<script>
  const X0 = 70, X1 = 650, Y0 = 30, Y1 = 280;
  const T_MAX_DEFAULT = 80;  // years of x-axis

  type Preset = {
    key: string;
    title: string;
    a_peak: number;   // %/yr
    sigma: number;    // yr
    k: number;        // %/yr^2
    t_max: number;    // yr axis range
  };

  const PRESETS: Record<string, Preset> = {
    engels:    { key: "engels",    title: "Engels' pause — Britain 1780-1840",           a_peak: 0.8,  sigma: 25,  k: 0.010, t_max: 80  },
    deindust:  { key: "deindust",  title: "US deindustrialisation 1980-",                a_peak: 0.5,  sigma: 20,  k: 0.005, t_max: 70  },
    soviet:    { key: "soviet",    title: "Post-Soviet transition 1991-2000",            a_peak: 8.0,  sigma: 3,   k: 0.50,  t_max: 30  },
    aghion:    { key: "aghion",    title: "Aghion-Bunel modest AI scenario",             a_peak: 0.7,  sigma: 8,   k: 0.04,  t_max: 40  },
    davidson:  { key: "davidson",  title: "Davidson radical AI scenario",                a_peak: 50.0, sigma: 2,   k: 3.0,   t_max: 15  },
    custom:    { key: "custom",    title: "Custom parameters",                           a_peak: 2.0,  sigma: 10,  k: 0.10,  t_max: 50  },
  };

  const IOTA_0 = 0.1;  // baseline institutional rate, %/yr

  function computeCurves(p: Preset, t_max: number) {
    const N = 400;
    const dt = t_max / N;
    const ts: number[] = [];
    const as_: number[] = [];
    const iotas: number[] = [];
    const gaps: number[] = [];
    for (let i = 0; i <= N; i++) {
      const t = i * dt;
      const a = p.a_peak * Math.exp(-0.5 * Math.pow((t - p.sigma) / (p.sigma / 1.4), 2));
      const iota = IOTA_0 + p.k * t;
      ts.push(t);
      as_.push(a);
      iotas.push(iota);
      gaps.push(Math.max(0, a - iota));
    }
    return { ts, as: as_, iotas, gaps, dt };
  }

  function summarise(ts: number[], gaps: number[], dt: number) {
    let area = 0;
    let peak = 0;
    let lastPositive = 0;
    let firstPositive = -1;
    for (let i = 0; i < gaps.length; i++) {
      if (gaps[i] > 0) {
        if (firstPositive < 0) firstPositive = ts[i];
        lastPositive = ts[i];
        area += gaps[i] * dt;
        if (gaps[i] > peak) peak = gaps[i];
      }
    }
    const length = firstPositive >= 0 ? (lastPositive - firstPositive) : 0;
    return { area, peak, length };
  }

  function pathFor(ts: number[], vals: number[], yMax: number, t_max: number): string {
    let d = "";
    for (let i = 0; i < ts.length; i++) {
      const x = X0 + (ts[i] / t_max) * (X1 - X0);
      const y = Y1 - (Math.max(0, vals[i]) / yMax) * (Y1 - Y0);
      d += `${i === 0 ? "M" : "L"}${x.toFixed(2)},${y.toFixed(2)} `;
    }
    return d;
  }

  function valleyPathFor(ts: number[], as_: number[], iotas: number[], yMax: number, t_max: number): string {
    // build polygon wrapping around (a above iota) regions
    const xFor = (t: number) => X0 + (t / t_max) * (X1 - X0);
    const yFor = (v: number) => Y1 - (Math.max(0, v) / yMax) * (Y1 - Y0);
    let d = "";
    let inRegion = false;
    const starts: number[] = [];
    const ends: number[] = [];
    for (let i = 0; i < ts.length; i++) {
      const above = as_[i] > iotas[i];
      if (above && !inRegion) { starts.push(i); inRegion = true; }
      if (!above && inRegion) { ends.push(i - 1); inRegion = false; }
    }
    if (inRegion) ends.push(ts.length - 1);
    for (let r = 0; r < starts.length; r++) {
      const s = starts[r], e = ends[r];
      // forward along a
      for (let i = s; i <= e; i++) {
        const x = xFor(ts[i]), y = yFor(as_[i]);
        d += `${i === s ? "M" : "L"}${x.toFixed(2)},${y.toFixed(2)} `;
      }
      // backward along iota
      for (let i = e; i >= s; i--) {
        const x = xFor(ts[i]), y = yFor(iotas[i]);
        d += `L${x.toFixed(2)},${y.toFixed(2)} `;
      }
      d += "Z ";
    }
    return d;
  }

  function yAxisMax(aPeak: number): number {
    // round up to a nice value
    if (aPeak <= 1) return 1.5;
    if (aPeak <= 2) return 3;
    if (aPeak <= 5) return 6;
    if (aPeak <= 10) return 12;
    if (aPeak <= 20) return 24;
    if (aPeak <= 50) return 60;
    return 100;
  }

  function setupAxisTicks(t_max: number, yMax: number) {
    const svgns = "http://www.w3.org/2000/svg";
    const xg = document.getElementById("vs-xticks");
    const yg = document.getElementById("vs-yticks");
    if (!xg || !yg) return;
    while (xg.firstChild) xg.removeChild(xg.firstChild);
    while (yg.firstChild) yg.removeChild(yg.firstChild);

    // x ticks: 5 divisions
    const nx = 5;
    for (let i = 0; i <= nx; i++) {
      const t = (t_max * i) / nx;
      const x = X0 + (i / nx) * (X1 - X0);
      const tick = document.createElementNS(svgns, "line");
      tick.setAttribute("x1", String(x));
      tick.setAttribute("y1", String(Y1));
      tick.setAttribute("x2", String(x));
      tick.setAttribute("y2", String(Y1 + 4));
      xg.appendChild(tick);
      const label = document.createElementNS(svgns, "text");
      label.setAttribute("x", String(x));
      label.setAttribute("y", String(Y1 + 16));
      label.setAttribute("text-anchor", "middle");
      label.textContent = t % 1 === 0 ? String(Math.round(t)) : t.toFixed(1);
      xg.appendChild(label);
    }

    // y ticks: 4 divisions
    const ny = 4;
    for (let i = 0; i <= ny; i++) {
      const v = (yMax * i) / ny;
      const y = Y1 - (i / ny) * (Y1 - Y0);
      const tick = document.createElementNS(svgns, "line");
      tick.setAttribute("x1", String(X0 - 4));
      tick.setAttribute("y1", String(y));
      tick.setAttribute("x2", String(X0));
      tick.setAttribute("y2", String(y));
      yg.appendChild(tick);
      const label = document.createElementNS(svgns, "text");
      label.setAttribute("x", String(X0 - 8));
      label.setAttribute("y", String(y + 4));
      label.setAttribute("text-anchor", "end");
      label.textContent = v < 10 ? v.toFixed(1) : String(Math.round(v));
      yg.appendChild(label);
    }
  }

  const select = document.getElementById("vs-preset") as HTMLSelectElement | null;
  const aSlider = document.getElementById("vs-apeak") as HTMLInputElement | null;
  const sigmaSlider = document.getElementById("vs-sigma") as HTMLInputElement | null;
  const kSlider = document.getElementById("vs-k") as HTMLInputElement | null;
  const aOut = document.getElementById("vs-apeak-out") as HTMLOutputElement | null;
  const sigmaOut = document.getElementById("vs-sigma-out") as HTMLOutputElement | null;
  const kOut = document.getElementById("vs-k-out") as HTMLOutputElement | null;
  const title = document.getElementById("vs-title") as SVGTextElement | null;
  const aPath = document.getElementById("vs-a") as SVGPathElement | null;
  const iotaPath = document.getElementById("vs-iota") as SVGPathElement | null;
  const valleyPath = document.getElementById("vs-valley") as SVGPathElement | null;
  const LOut = document.getElementById("vs-L") as HTMLElement | null;
  const depthOut = document.getElementById("vs-depth") as HTMLElement | null;
  const areaOut = document.getElementById("vs-area") as HTMLElement | null;

  function applyPreset(key: string) {
    const p = PRESETS[key] || PRESETS.custom;
    if (aSlider) aSlider.value = String(p.a_peak);
    if (sigmaSlider) sigmaSlider.value = String(p.sigma);
    if (kSlider) kSlider.value = String(p.k);
    if (title) title.textContent = p.title;
    render(p.t_max);
  }

  function render(t_max?: number) {
    if (!aSlider || !sigmaSlider || !kSlider || !aOut || !sigmaOut || !kOut) return;
    const a_peak = parseFloat(aSlider.value);
    const sigma = parseFloat(sigmaSlider.value);
    const k = parseFloat(kSlider.value);
    aOut.textContent = a_peak.toFixed(1);
    sigmaOut.textContent = sigma.toFixed(1);
    kOut.textContent = k.toFixed(3);

    const presetKey = select?.value || "custom";
    const preset = PRESETS[presetKey] || PRESETS.custom;
    const t_axis = t_max ?? preset.t_max;

    const p: Preset = { key: presetKey, title: preset.title, a_peak, sigma, k, t_max: t_axis };
    const { ts, as: as_, iotas, gaps, dt } = computeCurves(p, t_axis);
    const yMax = yAxisMax(a_peak);
    setupAxisTicks(t_axis, yMax);

    if (aPath) aPath.setAttribute("d", pathFor(ts, as_, yMax, t_axis));
    if (iotaPath) iotaPath.setAttribute("d", pathFor(ts, iotas, yMax, t_axis));
    if (valleyPath) valleyPath.setAttribute("d", valleyPathFor(ts, as_, iotas, yMax, t_axis));

    const { area, peak, length } = summarise(ts, gaps, dt);
    if (LOut) LOut.textContent = length > 0 ? `${length.toFixed(1)} yr` : "—";
    if (depthOut) depthOut.textContent = peak > 0 ? `${peak.toFixed(2)} pp/yr` : "—";
    if (areaOut) areaOut.textContent = area > 0 ? `${area.toFixed(1)} pp·yr` : "0";
  }

  select?.addEventListener("change", () => {
    applyPreset(select.value);
  });
  aSlider?.addEventListener("input", () => { if (select) select.value = "custom"; render(); });
  sigmaSlider?.addEventListener("input", () => { if (select) select.value = "custom"; render(); });
  kSlider?.addEventListener("input", () => { if (select) select.value = "custom"; render(); });

  applyPreset(select?.value || "aghion");
</script>
