---
---

<div id="hero-sim-wrap" class="absolute inset-0 flex items-center justify-center">
  <canvas
    id="hero-sim"
  ></canvas>
</div>

<script>
  import { FlameSimulation } from "./webgpu/FlameSimulation";
  import type { SimColors } from "./webgpu/FlameSimulation";
  import { isDark, observeTheme } from "./webgpu/utils";

  const LIGHT: SimColors = {
    alive: [0.0, 0.0, 0.0, 1.0],
    dead: [1.0, 1.0, 1.0, 1.0],
  };

  const DARK: SimColors = {
    alive: [1.0, 1.0, 1.0, 1.0],
    dead: [0.0, 0.0, 0.0, 1.0],
  };

  const canvas = document.getElementById("hero-sim") as HTMLCanvasElement | null;

  if (canvas) {
    const sim = new FlameSimulation({
      canvas,
      colors: isDark() ? DARK : LIGHT,
    });

    // Size canvas to title width x hero height
    function sizeToTitle() {
      const title = document.getElementById("hero-title");
      const hero = document.getElementById("hero");
      if (!title || !hero) return;
      const w = title.offsetWidth;
      const h = hero.offsetHeight;
      canvas.style.width = w + "px";
      canvas.style.height = h + "px";
      sim.handleResize();
    }

    // Horizontal drag rotates the camera; vertical movement scrolls the page.
    // On touch, we wait for a small movement to decide direction. If the gesture
    // is mostly horizontal we capture the pointer and rotate; otherwise we let
    // the browser handle scrolling.
    let rotating = false;
    let deciding = false;
    let startX = 0;
    let startY = 0;
    let lastX = 0;
    const SENSITIVITY = 0.004;
    const THRESHOLD = 5; // px before we commit to rotate vs scroll

    canvas.addEventListener("pointerdown", (e: PointerEvent) => {
      deciding = true;
      rotating = false;
      startX = e.clientX;
      startY = e.clientY;
      lastX = e.clientX;
    });

    canvas.addEventListener("pointermove", (e: PointerEvent) => {
      if (!deciding && !rotating) return;

      if (deciding) {
        const dx = Math.abs(e.clientX - startX);
        const dy = Math.abs(e.clientY - startY);
        if (dx < THRESHOLD && dy < THRESHOLD) return;
        if (dx > dy) {
          rotating = true;
          deciding = false;
          canvas.setPointerCapture(e.pointerId);
        } else {
          deciding = false;
          return;
        }
      }

      sim.theta += (e.clientX - lastX) * SENSITIVITY;
      lastX = e.clientX;
    });

    canvas.addEventListener("pointerup", (e: PointerEvent) => {
      if (rotating) canvas.releasePointerCapture(e.pointerId);
      rotating = false;
      deciding = false;
    });

    canvas.addEventListener("pointercancel", () => {
      rotating = false;
      deciding = false;
    });

    sim.start().then((ok) => {
      if (!ok) {
        canvas.remove();
        return;
      }

      document.getElementById("hero-overlay")?.classList.add("hidden");
      sizeToTitle();
      new ResizeObserver(() => sizeToTitle()).observe(document.getElementById("hero")!);
      observeTheme(() => sim.updateColors(isDark() ? DARK : LIGHT));
    });
  }
</script>
