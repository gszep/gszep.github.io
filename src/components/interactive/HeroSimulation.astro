---
---

<div id="hero-sim-wrap" class="absolute inset-0 flex items-center justify-center">
  <canvas
    id="hero-sim"
    style="touch-action: pan-y;"
  ></canvas>
</div>

<script>
  import { FlameSimulation } from "./webgpu/FlameSimulation";
  import type { SimColors } from "./webgpu/FlameSimulation";
  import { isDark, observeTheme } from "./webgpu/utils";

  const LIGHT: SimColors = {
    alive: [0.0, 0.0, 0.0, 1.0],
    dead: [1.0, 1.0, 1.0, 1.0],
  };

  const DARK: SimColors = {
    alive: [1.0, 1.0, 1.0, 1.0],
    dead: [0.0, 0.0, 0.0, 1.0],
  };

  const canvas = document.getElementById("hero-sim") as HTMLCanvasElement | null;

  if (canvas) {
    const sim = new FlameSimulation({
      canvas,
      colors: isDark() ? DARK : LIGHT,
    });

    // Size canvas to hero section
    function sizeToTitle() {
      const hero = document.getElementById("hero");
      if (!hero) return;
      const w = hero.offsetWidth;
      const h = hero.offsetHeight;
      canvas.style.width = w + "px";
      canvas.style.height = h + "px";
      sim.handleResize();
    }

    // Mouse: horizontal drag rotates camera (with directional threshold).
    // Touch: two-finger horizontal drag rotates; single finger scrolls normally.
    const SENSITIVITY = 0.004;
    const THRESHOLD = 5;

    // --- Mouse (pointer events, ignore touch) ---
    let mouseRotating = false;
    let mouseDeciding = false;
    let mouseStartX = 0;
    let mouseStartY = 0;
    let mouseLastX = 0;

    canvas.addEventListener("pointerdown", (e: PointerEvent) => {
      if (e.pointerType === "touch") return;
      mouseDeciding = true;
      mouseRotating = false;
      mouseStartX = e.clientX;
      mouseStartY = e.clientY;
      mouseLastX = e.clientX;
    });

    canvas.addEventListener("pointermove", (e: PointerEvent) => {
      if (e.pointerType === "touch") return;
      if (!mouseDeciding && !mouseRotating) return;

      if (mouseDeciding) {
        const dx = Math.abs(e.clientX - mouseStartX);
        const dy = Math.abs(e.clientY - mouseStartY);
        if (dx < THRESHOLD && dy < THRESHOLD) return;
        if (dx > dy) {
          mouseRotating = true;
          mouseDeciding = false;
          canvas.setPointerCapture(e.pointerId);
        } else {
          mouseDeciding = false;
          return;
        }
      }

      sim.theta += (e.clientX - mouseLastX) * SENSITIVITY;
      mouseLastX = e.clientX;
    });

    canvas.addEventListener("pointerup", (e: PointerEvent) => {
      if (e.pointerType === "touch") return;
      if (mouseRotating) canvas.releasePointerCapture(e.pointerId);
      mouseRotating = false;
      mouseDeciding = false;
    });

    canvas.addEventListener("pointercancel", (e: PointerEvent) => {
      if (e.pointerType === "touch") return;
      mouseRotating = false;
      mouseDeciding = false;
    });

    // --- Trackpad: horizontal two-finger scroll rotates ---
    canvas.addEventListener("wheel", (e: WheelEvent) => {
      if (Math.abs(e.deltaX) > Math.abs(e.deltaY)) {
        e.preventDefault();
        sim.theta += e.deltaX * SENSITIVITY * 0.5;
      }
    }, { passive: false });

    // --- Touch: one-finger horizontal or two-finger horizontal drag rotates ---
    let touchLastX = 0;
    let touchRotating = false;
    let touchDeciding = false;
    let touchStartX = 0;
    let touchStartY = 0;

    canvas.addEventListener("touchstart", (e: TouchEvent) => {
      if (e.touches.length === 2) {
        touchRotating = true;
        touchDeciding = false;
        touchLastX = (e.touches[0].clientX + e.touches[1].clientX) / 2;
      } else if (e.touches.length === 1) {
        touchDeciding = true;
        touchRotating = false;
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        touchLastX = e.touches[0].clientX;
      }
    }, { passive: true });

    canvas.addEventListener("touchmove", (e: TouchEvent) => {
      if (e.touches.length === 2 && touchRotating) {
        e.preventDefault();
        const midX = (e.touches[0].clientX + e.touches[1].clientX) / 2;
        sim.theta += (midX - touchLastX) * SENSITIVITY * 3;
        touchLastX = midX;
      } else if (e.touches.length === 1 && (touchDeciding || touchRotating)) {
        const x = e.touches[0].clientX;
        if (touchDeciding) {
          const dx = Math.abs(x - touchStartX);
          const dy = Math.abs(e.touches[0].clientY - touchStartY);
          if (dx < THRESHOLD && dy < THRESHOLD) return;
          if (dx > dy) {
            touchRotating = true;
            touchDeciding = false;
          } else {
            touchDeciding = false;
            return;
          }
        }
        sim.theta += (x - touchLastX) * SENSITIVITY * 3;
        touchLastX = x;
      }
    }, { passive: false });

    canvas.addEventListener("touchend", () => {
      touchRotating = false;
      touchDeciding = false;
    });
    canvas.addEventListener("touchcancel", () => {
      touchRotating = false;
      touchDeciding = false;
    });

    sim.start().then((ok) => {
      if (!ok) {
        canvas.remove();
        return;
      }

      document.getElementById("hero-overlay")?.classList.add("hidden");
      sizeToTitle();
      new ResizeObserver(() => sizeToTitle()).observe(document.getElementById("hero")!);
      observeTheme(() => sim.updateColors(isDark() ? DARK : LIGHT));
    });
  }
</script>
