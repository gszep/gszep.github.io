---
import Math from '../ui/Math.astro';
---

<div class="race-eq">
  <svg viewBox="0 0 640 360" preserveAspectRatio="xMidYMid meet" aria-label="Race equilibrium plot">
    <!-- axes -->
    <g class="axes">
      <line x1="60" y1="20" x2="60" y2="300" />
      <line x1="60" y1="300" x2="620" y2="300" />
      <!-- y ticks -->
      <g class="ticks">
        <line x1="56" y1="20"  x2="60" y2="20" />
        <line x1="56" y1="90"  x2="60" y2="90" />
        <line x1="56" y1="160" x2="60" y2="160" />
        <line x1="56" y1="230" x2="60" y2="230" />
        <line x1="56" y1="300" x2="60" y2="300" />
        <text x="52" y="24"  text-anchor="end">1.0</text>
        <text x="52" y="94"  text-anchor="end">0.75</text>
        <text x="52" y="164" text-anchor="end">0.5</text>
        <text x="52" y="234" text-anchor="end">0.25</text>
        <text x="52" y="304" text-anchor="end">0</text>
      </g>
      <!-- x ticks -->
      <g class="ticks">
        <line x1="60"  y1="300" x2="60"  y2="304" />
        <line x1="200" y1="300" x2="200" y2="304" />
        <line x1="340" y1="300" x2="340" y2="304" />
        <line x1="480" y1="300" x2="480" y2="304" />
        <line x1="620" y1="300" x2="620" y2="304" />
        <text x="60"  y="318" text-anchor="middle">1</text>
        <text x="200" y="318" text-anchor="middle">6</text>
        <text x="340" y="318" text-anchor="middle">11</text>
        <text x="480" y="318" text-anchor="middle">16</text>
        <text x="620" y="318" text-anchor="middle">21</text>
      </g>
      <text x="340" y="345" text-anchor="middle" class="axlabel">teams, <tspan class="math-italic">N</tspan></text>
      <text transform="translate(18,160) rotate(-90)" text-anchor="middle" class="axlabel">safety at equilibrium, <tspan class="math-italic">s</tspan><tspan class="math-italic" dy="-4" font-size="9">*</tspan></text>
    </g>

    <!-- curve -->
    <path id="race-curve" class="curve" />
    <circle id="race-dot" r="5" class="dot" />
    <text id="race-label" class="readout" text-anchor="start"></text>
  </svg>

  <div class="controls">
    <label>
      <span><Math tex="N" /> (teams) = <output id="race-n">5</output></span>
      <input type="range" id="race-n-slider" min="1" max="21" step="1" value="5" />
    </label>
    <label>
      <span><Math tex="e" /> (enmity) = <output id="race-e">0.3</output></span>
      <input type="range" id="race-e-slider" min="0.1" max="1" step="0.01" value="0.3" />
    </label>
  </div>
</div>

<style>
  .race-eq {
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    color: var(--post-text, #353535);
    font-family: ui-sans-serif, system-ui, sans-serif;
  }
  .race-eq svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .race-eq .axes line { stroke: var(--post-separator, #bbb); stroke-width: 1; }
  .race-eq .ticks line { stroke: var(--post-separator, #bbb); }
  .race-eq .ticks text,
  .race-eq .axlabel {
    fill: var(--post-caption, #737373);
    font-size: 11px;
  }
  .race-eq .axlabel { font-size: 12px; }
  .race-eq .math-italic {
    font-family: 'KaTeX_Math', 'Times New Roman', serif;
    font-style: italic;
  }
  .race-eq .curve {
    fill: none;
    stroke: var(--post-link, #2563eb);
    stroke-width: 2.5;
  }
  .race-eq .dot {
    fill: var(--post-heading, #1a1a1a);
  }
  .race-eq .readout {
    fill: var(--post-heading, #1a1a1a);
    font-size: 13px;
    font-weight: 600;
  }
  .race-eq .controls {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 0.75rem;
    font-size: 0.9rem;
  }
  @media (max-width: 520px) {
    .race-eq .controls { grid-template-columns: 1fr; }
  }
  .race-eq .controls label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    color: var(--post-caption, #737373);
  }
  .race-eq .controls input[type="range"] {
    accent-color: var(--post-link, #2563eb);
    width: 100%;
  }
  .race-eq .controls output {
    color: var(--post-heading, #1a1a1a);
    font-weight: 600;
  }
</style>

<script>
  // Stylised Armstrong–Bostrom–Shulman symmetric equilibrium.
  // s*(N, e) shrinks as teams and enmity grow.
  function safetyStar(N: number, e: number): number {
    return 1 / (1 + (N - 1) * e * 3);
  }

  const X0 = 60, X1 = 620, Y0 = 20, Y1 = 300;
  const xFor = (n: number) => X0 + ((n - 1) / 20) * (X1 - X0);
  const yFor = (s: number) => Y1 - s * (Y1 - Y0);

  const svgCurve = document.getElementById("race-curve") as SVGPathElement | null;
  const dot = document.getElementById("race-dot") as SVGCircleElement | null;
  const label = document.getElementById("race-label") as SVGTextElement | null;
  const nSlider = document.getElementById("race-n-slider") as HTMLInputElement | null;
  const eSlider = document.getElementById("race-e-slider") as HTMLInputElement | null;
  const nOut = document.getElementById("race-n") as HTMLOutputElement | null;
  const eOut = document.getElementById("race-e") as HTMLOutputElement | null;

  function render() {
    if (!svgCurve || !dot || !label || !nSlider || !eSlider || !nOut || !eOut) return;
    const N = parseInt(nSlider.value, 10);
    const e = parseFloat(eSlider.value);

    const pts: string[] = [];
    for (let n = 1; n <= 21; n++) {
      const s = safetyStar(n, e);
      pts.push(`${n === 1 ? "M" : "L"}${xFor(n).toFixed(1)},${yFor(s).toFixed(1)}`);
    }
    svgCurve.setAttribute("d", pts.join(" "));

    const s = safetyStar(N, e);
    const cx = xFor(N), cy = yFor(s);
    dot.setAttribute("cx", String(cx));
    dot.setAttribute("cy", String(cy));

    nOut.textContent = String(N);
    eOut.textContent = e.toFixed(2);

    const lx = Math.min(cx + 10, 540);
    const ly = Math.max(cy - 10, 30);
    label.setAttribute("x", String(lx));
    label.setAttribute("y", String(ly));
    label.textContent = `N=${N}, e=${e.toFixed(2)} →  s* = ${s.toFixed(2)}`;
  }

  nSlider?.addEventListener("input", render);
  eSlider?.addEventListener("input", render);
  render();
</script>
